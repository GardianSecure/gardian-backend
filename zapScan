// zapScan.js
const axios = require("axios");

const zapPort = process.env.ZAP_PORT || 8080; // must match launch.js
const ZAP_API = `http://127.0.0.1:${zapPort}`;
const API_KEY = process.env.ZAP_API_KEY;
const fetch = require("node-fetch");

if (!API_KEY) {
  throw new Error("ZAP_API_KEY must be set in environment variables");
}

const sleep = ms => new Promise(r => setTimeout(r, ms));

function normalizeRisk(risk) {
  if (!risk) return "Informational";
  const r = risk.toLowerCase();
  if (r === "high") return "High";
  if (r === "medium") return "Medium";
  if (r === "low") return "Low";
  return "Informational";
}

async function waitForZapReady(maxMs = 600000) {
  await sleep(5000);
  const deadline = Date.now() + maxMs;
  while (Date.now() < deadline) {
    try {
      const res = await axios.get(`${ZAP_API}/JSON/core/view/version/`, { params: { apikey: API_KEY } });
      if (res.data) {
        console.log("✅ ZAP API is online:", res.data);
        return true;
      }
    } catch {
      console.log("⏳ Waiting for ZAP API...");
    }
    await sleep(3000);
  }
  throw new Error("❌ ZAP API did not become ready in time");
}

async function waitForImplementors(maxMs = 300000) {
  const deadline = Date.now() + maxMs;
  while (Date.now() < deadline) {
    let spiderOK = false;
    let ascanOK = false;
    try { await axios.get(`${ZAP_API}/JSON/spider/view/scans/`, { params: { apikey: API_KEY } }); spiderOK = true; } catch {}
    try { await axios.get(`${ZAP_API}/JSON/ascan/view/scans/`, { params: { apikey: API_KEY } }); ascanOK = true; } catch {}
    if (spiderOK && ascanOK) {
      console.log("✅ Implementors ready: spider + ascan");
      return true;
    }
    console.log(`⏳ Implementors not ready yet (spider=${spiderOK}, ascan=${ascanOK})`);
    await sleep(3000);
  }
  throw new Error("❌ Required implementors (spider/ascan) not ready in time");
}

async function runZapScan(siteUrl) {
  const zapApi = `http://localhost:${process.env.ZAP_PORT || 8080}`;
  try {
    console.log(`🔍 Starting ZAP scan for ${siteUrl}`);

    // Spider
    const spiderResp = await fetch(
      `${zapApi}/JSON/spider/action/scan/?url=${encodeURIComponent(siteUrl)}`
    );
    const spiderData = await spiderResp.json();
    if (!spiderData.scan) throw new Error("Spider scan failed to start");

    let spiderProgress = 0;
    while (spiderProgress < 100) {
      const statusResp = await fetch(`${zapApi}/JSON/spider/view/status/?scanId=${spiderData.scan}`);
      const statusData = await statusResp.json();
      spiderProgress = parseInt(statusData.status, 10);
      console.log(`🕷️ Spider progress: ${spiderProgress}%`);
      await new Promise(r => setTimeout(r, 2000));
    }
    console.log("✅ Spider scan complete");

    // Active scan
    const activeResp = await fetch(
      `${zapApi}/JSON/ascan/action/scan/?url=${encodeURIComponent(siteUrl)}`
    );
    const activeData = await activeResp.json();
    if (!activeData.scan) throw new Error("Active scan failed to start");

    let activeProgress = 0;
    while (activeProgress < 100) {
      const statusResp = await fetch(`${zapApi}/JSON/ascan/view/status/?scanId=${activeData.scan}`);
      const statusData = await statusResp.json();
      activeProgress = parseInt(statusData.status, 10);
      console.log(`⚡ Active scan progress: ${activeProgress}%`);
      await new Promise(r => setTimeout(r, 5000));
    }
    console.log("✅ Active scan complete");

    // Delay before fetching alerts
    await sleep(30000);

    // Alerts
    const alertsResp = await fetch(
      `${zapApi}/JSON/core/view/alerts/?baseurl=${encodeURIComponent(siteUrl)}&start=0&count=100`
    );
    const alertsData = await alertsResp.json();

    return {
      status: "Complete",
      alerts: alertsData.alerts || []
    };
  } catch (err) {
    console.error("❌ ZAP scan error:", err.message);
    return { status: "Error", alerts: [] };
  }
}

module.exports = runZapScan;
